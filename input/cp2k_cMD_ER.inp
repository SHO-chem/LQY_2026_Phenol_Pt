&FORCE_EVAL
  METHOD Quickstep
  &DFT
      UKS F
      BASIS_SET_FILE_NAME  /share/apps/cp2k/cp2k-7.1-intel/data/BASIS_MOLOPT
      POTENTIAL_FILE_NAME  /share/apps/cp2k/cp2k-7.1-intel/data/GTH_POTENTIALS
      WFN_RESTART_FILE_NAME ./1-RESTART.wfn 
    &MGRID
      NGRIDS 20
      CUTOFF 400
      REL_CUTOFF 40
    &END MGRID
    &QS
      EPS_DEFAULT 1.0E-12
      EPS_PGF_ORB 1.0E-6
      EXTRAPOLATION ASPC
      EXTRAPOLATION_ORDER 3
    &END QS

    &SCF
      MAX_SCF 30
      EPS_SCF 1.0E-5
      SCF_GUESS ATOMIC
      ADDED_MOS 50
      &SMEAR
       METHOD FERMI_DIRAC
      &END SMEAR
      &DIAGONALIZATION
      ALGORITHM STANDARD
      &END DIAGONALIZATION

      &OUTER_SCF
        MAX_SCF 50
        EPS_SCF 1.0E-05
      &END OUTER_SCF
      &MIXING ON 
        METHOD BROYDEN_MIXING
        ALPHA 0.2
        BETA 1.5
        NBROYDEN 32
      &END MIXING
      &PRINT
        &RESTART_HISTORY
          FILENAME = MD_RESTART_HISTORY.wfn
          ADD_LAST NUMERIC
          BACKUP_COPIES 5
        &END
      &END
     &END SCF
     &XC
      &XC_FUNCTIONAL PBE
      &END XC_FUNCTIONAL
      &XC_GRID
       XC_SMOOTH_RHO NN10
       XC_DERIV SPLINE2_SMOOTH
      &END XC_GRID
      &vdW_POTENTIAL
        POTENTIAL_TYPE PAIR_POTENTIAL
        &PAIR_POTENTIAL
         TYPE DFTD3
         PARAMETER_FILE_NAME /share/apps/cp2k/cp2k-7.1-intel/data/dftd3.dat
         REFERENCE_FUNCTIONAL PBE
         R_CUTOFF 10.                                                                                                                              
        &END
      &END vdW_POTENTIAL 
    &END XC
  &END DFT
  &SUBSYS
    &CELL
      ABC [angstrom] 11.0985   14.4173   26.7964
      PERIODIC XYZ
    &END CELL

    &TOPOLOGY
      CONNECTIVITY  OFF
      COORD_FILE_NAME init.xyz
      COORDINATE XYZ
    &END TOPOLOGY


    &KIND C
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q4
    &END KIND

    &KIND H
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q1
      MASS 2.0
    &END KIND

    &KIND O
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q6
    &END KIND

    &KIND Pt
      BASIS_SET DZVP-MOLOPT-SR-GTH
      POTENTIAL GTH-PBE-q18
    &END KIND

    &COLVAR
       &COMBINE_COLVAR
         &COLVAR
            &DISTANCE
              ATOMS 260 267
            &END DISTANCE
         &END COLVAR
         &COLVAR
            &DISTANCE_POINT_PLANE
              ATOMS_PLANE 80 74 73
              ATOM_POINT 260
            &END DISTANCE_POINT_PLANE
         &END COLVAR
         VARIABLES CV1 CV2
         PARAMETERS A B
         VALUES 1 -1
         FUNCTION B*CV2-A*CV1
       &END COMBINE_COLVAR
    &END COLVAR
  &END SUBSYS

&END FORCE_EVAL

&GLOBAL
  PROJECT 1
  RUN_TYPE MD
  PRINT_LEVEL LOW
&END GLOBAL

&MOTION
  &MD
    ENSEMBLE NVT
    STEPS  2000
    TIMESTEP 1.0
    TEMPERATURE 300.0
    TEMP_TOL   100
    &THERMOSTAT
      &NOSE
        LENGTH 3
        YOSHIDA 3
        TIMECON 100.0
        MTS 2
      &END NOSE
    &END
    ANGVEL_ZERO
    COMVEL_TOL  2.0E-7

    &PRINT
      &ENERGY
        &EACH
           MD 1
        &END
      &END

      &PROGRAM_RUN_INFO
        &EACH
           MD 100
        &END
      &END
      FORCE_LAST
    &END PRINT
  &END MD

  &PRINT
    &TRAJECTORY
      &EACH
        MD 5
      &END
    &END
    &VELOCITIES OFF
    &END
    &RESTART
      &EACH
         MD 10
      &END
      ADD_LAST NUMERIC
    &END
    &RESTART_HISTORY 
      &EACH
         MD 500
      &END
    &END
  &END
  &CONSTRAINT
    &FIXED_ATOMS
      LIST   1..48
    &END
    &COLLECTIVE
      COLVAR 1
      INTERMOLECULAR T
      TARGET [angstrom] -1.3
    &END
    &LAGRANGE_MULTIPLIERS
    COMMON_ITERATION_LEVELS 1
    &END LAGRANGE_MULTIPLIERS
  &END
&END MOTION

